# Local-only source material. Only the policy README is public.
/materials-private/**
!/materials-private/README.md

# Codex/workspace runtime metadata
/.agents/
/.codex/
/.playwright-cli/

# Office temporary files
~$*
*.tmp
*.temp
*.asd
*.wbk

# AutoCAD temporary and recovery files
*.bak
*.dwl
*.dwl2
*.sv$
*.ac$
*.autosave
*.err
*.log

# Cloud-sync transient files
*.baiduyun.uploading.cfg

# Local environments and caches
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local QA/rendering scratch space
/tmp/
/.tmp/
/output/qa/
/drawings/exports/*_raw.pdf

# Submission bundles and large media stay outside source history
/deliverables/*.zip
/deliverables/*.7z
/deliverables/*.rar
*.mp4
*.mp3

# Secrets and machine-local configuration
.env
.env.*
!.env.example
*.pem
*.key
credentials*.json

# OS noise
Thumbs.db
Desktop.ini
.DS_Store
